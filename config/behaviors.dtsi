#define HYPER LC(LA(LS(LGUI)))

/ {
    behaviors {
        skq: sticky_key_quick_release {
            compatible = "zmk,behavior-sticky-key";
            #binding-cells = <1>;
            bindings = <&kp>;
            release-after-ms = <1000>;
            quick-release;
            ignore-modifiers;
        };

        num_shift: num_layer_sticky_shift {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            bindings = <&mo>, <&skq>;
            flavor = "hold-preferred";
            tapping-term-ms = <200>;
        };

        tog_on: toggle_layer_on_only {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Toggle Layer On";
            toggle-mode = "on";
        };

        tog_off: toggle_layer_off_only {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Toggle Layer Off";
            toggle-mode = "off";
        };
    };

    macros {
        num_hold_cleanup: num_hold_cleanup {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press &mo NUM>
                , <&macro_pause_for_release>
                , <&macro_tap &tog_off FUN &tog_off NUM>
                , <&macro_release &mo NUM>
                ;
        };

        sw_gui_next: switch_gui_next {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SWITCH &kp LGUI>
                , <&macro_tap &kp TAB>
                , <&macro_pause_for_release>
                , <&macro_release &mo SWITCH &kp LGUI>
                ;
        };

        sw_gui_prev: switch_gui_prev {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SWITCH &kp LGUI>
                , <&macro_press &kp LSHIFT>
                , <&macro_tap &kp TAB>
                , <&macro_release &kp LSHIFT>
                , <&macro_pause_for_release>
                , <&macro_release &mo SWITCH &kp LGUI>
                ;
        };

        sw_ctl_next: switch_ctl_next {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SWITCH &kp LCTRL>
                , <&macro_tap &kp TAB>
                , <&macro_pause_for_release>
                , <&macro_release &mo SWITCH &kp LCTRL>
                ;
        };

        sw_ctl_prev: switch_ctl_prev {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SWITCH &kp LCTRL>
                , <&macro_press &kp LSHIFT>
                , <&macro_tap &kp TAB>
                , <&macro_release &kp LSHIFT>
                , <&macro_pause_for_release>
                , <&macro_release &mo SWITCH &kp LCTRL>
                ;
        };

        sw_alt_next: switch_alt_next {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SWITCH &kp LALT>
                , <&macro_tap &kp TAB>
                , <&macro_pause_for_release>
                , <&macro_release &mo SWITCH &kp LALT>
                ;
        };

        sw_alt_prev: switch_alt_prev {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SWITCH &kp LALT>
                , <&macro_press &kp LSHIFT>
                , <&macro_tap &kp TAB>
                , <&macro_release &kp LSHIFT>
                , <&macro_pause_for_release>
                , <&macro_release &mo SWITCH &kp LALT>
                ;
        };

        mac_line_start: mac_line_start {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LG(LEFT)>;
        };

        mac_line_end: mac_line_end {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LG(RIGHT)>;
        };

        mac_word_left: mac_word_left {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LA(LEFT)>;
        };

        mac_word_right: mac_word_right {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LA(RIGHT)>;
        };

        mac_select_line: mac_select_line {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_tap &kp LG(LEFT)>
                , <&macro_tap &kp LS(LG(RIGHT))>
                ;
        };

        mac_select_word: mac_select_word {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_tap &kp LA(LEFT)>
                , <&macro_tap &kp LS(LA(RIGHT))>
                ;
        };

        mac_delete_word_bck: mac_delete_word_bck {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LA(BACKSPACE)>;
        };

        mac_delete_word_fwd: mac_delete_word_fwd {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LA(DELETE)>;
        };

        mac_delete_line_bck: mac_delete_line_bck {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LG(BACKSPACE)>;
        };

        mac_delete_line_fwd: mac_delete_line_fwd {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LG(DELETE)>;
        };

        win_line_start: win_line_start {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp HOME>;
        };

        win_line_end: win_line_end {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp END>;
        };

        win_word_left: win_word_left {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LC(LEFT)>;
        };

        win_word_right: win_word_right {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LC(RIGHT)>;
        };

        win_select_line: win_select_line {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_tap &kp HOME>
                , <&macro_tap &kp LS(END)>
                ;
        };

        win_select_word: win_select_word {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_tap &kp LC(LEFT)>
                , <&macro_tap &kp LS(LC(RIGHT))>
                ;
        };

        win_delete_word_bck: win_delete_word_bck {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LC(BACKSPACE)>;
        };

        win_delete_word_fwd: win_delete_word_fwd {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings = <&macro_tap &kp LC(DELETE)>;
        };

        win_delete_line_bck: win_delete_line_bck {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_tap &kp LS(HOME)>
                , <&macro_tap &kp BACKSPACE>
                ;
        };

        win_delete_line_fwd: win_delete_line_fwd {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_tap &kp LS(END)>
                , <&macro_tap &kp DELETE>
                ;
        };

        pair_lpar: pair_lpar {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SYM_PAIR>
                , <&macro_tap &kp LPAR>
                , <&macro_pause_for_release>
                , <&macro_release &mo SYM_PAIR>
                ;
        };

        pair_lbrc: pair_lbrc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SYM_PAIR>
                , <&macro_tap &kp LBRC>
                , <&macro_pause_for_release>
                , <&macro_release &mo SYM_PAIR>
                ;
        };

        pair_rpar: pair_rpar {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SYM_PAIR>
                , <&macro_tap &kp RPAR>
                , <&macro_pause_for_release>
                , <&macro_release &mo SYM_PAIR>
                ;
        };

        pair_rbrc: pair_rbrc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SYM_PAIR>
                , <&macro_tap &kp RBRC>
                , <&macro_pause_for_release>
                , <&macro_release &mo SYM_PAIR>
                ;
        };

        pair_lbkt: pair_lbkt {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SYM_PAIR>
                , <&macro_tap &kp LBKT>
                , <&macro_pause_for_release>
                , <&macro_release &mo SYM_PAIR>
                ;
        };

        pair_rbkt: pair_rbkt {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <20>;
            bindings
                = <&macro_press &mo SYM_PAIR>
                , <&macro_tap &kp RBKT>
                , <&macro_pause_for_release>
                , <&macro_release &mo SYM_PAIR>
                ;
        };
    };
};
